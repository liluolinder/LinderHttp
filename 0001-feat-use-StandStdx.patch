From cd1f09c68f7aaca316938aaac03146c611274f43 Mon Sep 17 00:00:00 2001
From: yms <yms_hi@outlook.com>
Date: Tue, 27 Jan 2026 19:29:00 +0800
Subject: [PATCH] feat: use StandStdx

---
 cjpm.toml                 | 28 +++++-----------------------
 src/commons/importFIle.cj |  6 +++---
 src/importFIle.cj         | 10 +++++-----
 src/utils/importFIle.cj   |  8 ++++----
 4 files changed, 17 insertions(+), 35 deletions(-)

diff --git a/cjpm.toml b/cjpm.toml
index 0487875..21c9a58 100644
--- a/cjpm.toml
+++ b/cjpm.toml
@@ -11,26 +11,8 @@
   [package.package-configuration]
 
 [dependencies]
-  
-[target]
-  [target.aarch64-linux-ohos]
-    compile-option = "-B \"${DEVECO_CANGJIE_HOME}/build-tools/third_party/llvm/bin\" -B \"${DEVECO_OH_NATIVE_HOME}/sysroot/usr/lib/aarch64-linux-ohos\" -L \"${DEVECO_OH_NATIVE_HOME}/sysroot/usr/lib/aarch64-linux-ohos\" -L \"${DEVECO_OH_NATIVE_HOME}/llvm/lib/clang/15.0.4/lib/aarch64-linux-ohos\" -L \"${DEVECO_OH_NATIVE_HOME}/llvm/lib/aarch64-linux-ohos\" --sysroot \"${DEVECO_OH_NATIVE_HOME}/sysroot\""
-    [target.aarch64-linux-ohos.bin-dependencies]
-      path-option = [ "${AARCH64_LIBS}", "${AARCH64_MACRO_LIBS}", "${AARCH64_KIT_LIBS}", "${CANGJIE_STDX_PATH}/linux_ohos_aarch64_cjnative/static/stdx" ]
-  [target.x86_64-linux-ohos]
-    compile-option = "-B \"${DEVECO_CANGJIE_HOME}/build-tools/third_party/llvm/bin\" -B \"${DEVECO_OH_NATIVE_HOME}/sysroot/usr/lib/x86_64-linux-ohos\" -L \"${DEVECO_OH_NATIVE_HOME}/sysroot/usr/lib/x86_64-linux-ohos\" -L \"${DEVECO_OH_NATIVE_HOME}/llvm/lib/clang/15.0.4/lib/x86_64-linux-ohos\" -L \"${DEVECO_OH_NATIVE_HOME}/llvm/lib/x86_64-linux-ohos\" --sysroot \"${DEVECO_OH_NATIVE_HOME}/sysroot\""
-    [target.x86_64-linux-ohos.bin-dependencies]
-      path-option = [ "${X86_64_OHOS_LIBS}", "${X86_64_OHOS_MACRO_LIBS}", "${X86_64_OHOS_KIT_LIBS}", "${CANGJIE_STDX_PATH}/linux_ohos_x86_64_cjnative/static/stdx" ]
-  [target.x86_64-unknown-linux-gnu]
-    compile-option = "--cfg \"ohos=false\""
-    [target.x86_64-unknown-linux-gnu.bin-dependencies]
-      path-option = [ "${CANGJIE_STDX_PATH}/linux_x86_64_llvm/static/stdx" ]
-  [target.aarch64-unknown-linux-gnu]
-    compile-option = "--cfg \"ohos=false\""
-    [target.aarch64-unknown-linux-gnu.bin-dependencies]
-      path-option = [ "${CANGJIE_STDX_PATH}/linux_aarch64_llvm/static/stdx" ]
-  [target.x86_64-w64-mingw32]
-    compile-option = "--cfg \"ohos=false\""
-    link-option = "-lcrypt32"
-    [target.x86_64-w64-mingw32.bin-dependencies]
-      path-option = [ "${CANGJIE_STDX_PATH}/windows_x86_64_cjnative/static/stdx" ]
+  stdx_encode = {path = "D:/stdx/stdx_standalone_encode"}
+  stdx_encode_json = {path = "D:/stdx/stdx_standalone_encode_json"}
+  stdx_net = {path = "D:/stdx/stdx_standalone_net"}
+  stdx_serialization = {path = "D:/stdx/stdx_standalone_serialization"}
+  
\ No newline at end of file
diff --git a/src/commons/importFIle.cj b/src/commons/importFIle.cj
